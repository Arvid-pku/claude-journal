{
  "name": "claude-journal",
  "version": "1.4.0",
  "description": "View, annotate, search, and analyze your Claude Code conversation history",
  "main": "server.js",
  "bin": {
    "claude-journal": "bin/cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "playwright test",
    "build": "npx pkg bin/cli.js --targets node18-macos-x64,node18-macos-arm64,node18-linux-x64,node18-win-x64 --out-path dist --compress GZip"
  },
  "keywords": [
    "claude", "claude-code", "conversation", "history", "journal",
    "annotations", "analytics", "search", "highlights", "notes"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arvid-pku/claude-journal.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "server.js",
    "bin/",
    "public/",
    "providers/"
  ],
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^5.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
